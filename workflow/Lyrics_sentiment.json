      "name": "lyrics from url"
    },
    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\n\nconst regex = /<div[^>]*data-lyrics-container=\"true\"[^>]*>(.*?)<\\/div>/gs;\nconst matches = [...html.matchAll(regex)];\n\nlet lyrics = matches.map(m => m[1]).join('\\n');\n\nlyrics = lyrics\n  .replace(/<br\\s*\\/?>/g, '\\n')\n  .replace(/<[^>]+>/g, '')\n  .replace(/&amp;/g, '&')\n  .replace(/&#x27;/g, \"'\")\n  .replace(/&quot;/g, '\"')\n  .trim();\nlyrics = lyrics.replace(/^[\\s\\S]*?(?=\\[(Chorus|Verse|Bridge|Intro|Outro|Pre-Chorus|Hook))/, '');\nreturn [{ json: { lyrics } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        112
      ],
      "id": "76289ccb-eec2-45d5-b9e3-6732c6378481",
