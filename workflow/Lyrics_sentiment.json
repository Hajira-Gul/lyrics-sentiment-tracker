            {
              "content": "=You are a music lyric analyst. Given song lyrics, analyze the mood and themes. Respond ONLY with valid JSON, no markdown, no other text, in this exact format:\n{\n  \"mood\": \"one or two words describing overall mood\",\n  \"sentiment_score\": a number between -1 and 1,\n  \"themes\": [\"theme1\", \"theme2\", \"theme3\"],\n  \"summary\": \"one sentence summary of what the song is about\"\n}\n\nHere are the lyrics:\n{{ $json.lyrics }}"
            }
          ]
        },
        "simplify": false,
